# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pulsar
POSTGRES_USER=pulsar
POSTGRES_PASSWORD=pulsar_dev

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=pulsar_dev

# RocketRide
ROCKETRIDE_URI=http://localhost:5565
ROCKETRIDE_APIKEY=
ROCKETRIDE_ANTHROPIC_KEY=

# Firecrawl (used by fetchRocketRideContext for site scrapes)
FIRECRAWL_API_KEY=

# GitHub (optional, lifts public-API rate limits for README fetch)
GITHUB_TOKEN=


# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# OAuth (GitHub only)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=

# Scheduler (scrape at 5:30am, pipeline runs automatically after)
SCRAPER_CRON="30 5 * * *"
SCRAPER_MAX_ITEMS_PER_SOURCE=100

# Trend scoring
TREND_SCORE_LAMBDA=0.1
