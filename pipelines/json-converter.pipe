{
  "components": [
    {
      "id": "webhook_1",
      "provider": "webhook",
      "config": {
        "hideForm": true,
        "mode": "Source",
        "parameters": {},
        "type": "webhook"
      }
    },
    {
      "id": "parse_1",
      "provider": "parse",
      "config": {},
      "input": [
        {
          "lane": "tags",
