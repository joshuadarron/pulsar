        }
      ]
    },
    {
      "id": "question_1",
      "provider": "question",
      "config": {
        "profile": "default",
        "default": {
          "question": "Convert the following text into a valid JSON object. Output ONLY the raw JSON with no markdown, no explanation, no code fences. Your entire response must start with { and end with }."
        },
        "parameters": {}
      },
      "input": [
        {
          "lane": "text",
          "from": "parse_1"
        }
      ]
    },
    {
      "id": "llm_anthropic_1",
      "provider": "llm_anthropic",
      "config": {
        "profile": "claude-sonnet-4-6",
        "claude-sonnet-4-6": {
          "apikey": "${ROCKETRIDE_ANTHROPIC_KEY}"
        },
        "parameters": {}
      },
      "input": [
        {
          "lane": "questions",
          "from": "question_1"
        }
      ]
    },
    {
      "id": "response_answers_1",
      "provider": "response_answers",
      "config": {
        "laneName": "answers"
      },
      "input": [
        {
          "lane": "answers",
          "from": "llm_anthropic_1"
        }
      ]
    }
  ],
  "project_id": "a1b2c3d4-json-conv-0001-000000000001",
