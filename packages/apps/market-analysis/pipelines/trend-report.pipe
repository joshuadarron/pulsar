      "id": "question_1",
      "provider": "question",
      "name": "Question",
      "config": {
        "profile": "default",
        "default": {
          "question": "You will receive a JSON payload with two fields: \"prompt\" (your task instructions for this pass) and \"data\" (read-only input, either structured data or text from prior passes). Follow the prompt instructions exactly. Respond with ONLY a raw JSON object as specified in your system instructions. No markdown fences, no preamble."
        },
        "parameters": {}
      },
      "ui": {
        "position": {
          "x": 470,
          "y": 60
        },
        "nodeType": "default",
        "formDataValid": true
