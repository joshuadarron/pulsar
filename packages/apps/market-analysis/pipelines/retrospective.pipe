      "name": "Question",
      "config": {
        "profile": "default",
        "default": {
          "question": "Grade the past prediction in the payload using the data from start_date forward. Use Postgres, Neo4j, and Python to gather evidence. Return only the JSON envelope specified in your system instructions, no preamble, no markdown fences."
        },
        "parameters": {}
      },
      "ui": {
        "position": {
          "x": 472,
          "y": 86
        },
        "nodeType": "default",
        "formDataValid": true
      },
