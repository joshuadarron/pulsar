          "from": "parse_1"
        }
      ]
    },
    {
      "id": "grader_agent",
      "provider": "agent_deepagent",
      "name": "Retrospective Grader",
      "config": {
        "default": {
          "advanced_mode": true,
          "agent_description": "Grades a single past prediction against the data accumulated since the prediction date. Uses Postgres for article/topic/entity counts and graph snapshot diffs, Neo4j for live graph traversal, Python for numerical comparisons. Returns a verdict with evidence.",
          "system_prompt": "You grade a single past prediction. Input payload: prediction (prediction_text, predicted_entities, predicted_topics, prediction_type, made_at), query_window (start_date, end_date).\n\nUse your tools to gather evidence:\n- Postgres: count articles mentioning the predicted entities and topics by week in the query window. Look at sentiment shifts, topic frequencies. Read graph_snapshots rows with computed_at near start_date and end_date to compute PageRank rank deltas for predicted entities and mention count growth.\n- Neo4j: confirm live graph traversal where helpful (entity neighborhoods, topic co-occurrence shifts).\n- Python: numerical comparisons, deltas.\n\nRender a verdict using exactly one outcome value:\n- confirmed: the prediction landed (predicted entities/topics rose significantly per the data)\n- partially_confirmed: directionally right, magnitude or specifics off\n- refuted: the predicted thing did not happen, or the opposite happened\n- inconclusive: insufficient signal in the data to grade\n\nBe conservative: if evidence is mixed, prefer partially_confirmed over confirmed. If evidence is missing, use inconclusive. No em-dashes anywhere. Use commas, colons, periods, parentheses.\n\nOutput exactly this JSON shape, no preamble, no markdown fences:\n\n{\"outcome\": \"confirmed|partially_confirmed|refuted|inconclusive\", \"evidence_summary\": \"2-3 sentences citing specific numbers from your queries\", \"evidence_data\": {\"queries_run\": [\"...\"], \"key_metrics\": {}}}"
        },
        "parameters": {}
      },
      "ui": {
        "position": {
          "x": 702,
          "y": 62
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "questions",
          "from": "question_1"
        }
      ]
    },
    {
      "id": "llm_anthropic_1",
      "provider": "llm_anthropic",
      "name": "Anthropic Haiku",
      "config": {
        "profile": "claude-haiku-4-5",
        "claude-haiku-4-5": {
          "apikey": "${ROCKETRIDE_ANTHROPIC_KEY}"
        },
        "parameters": {}
      },
      "ui": {
