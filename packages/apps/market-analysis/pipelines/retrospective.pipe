          "database": "pulsar",
          "table": "articles",
          "db_description": "Pulsar market intelligence database. Key tables: articles (id, url, title, summary, content_type, sentiment, topic_tags[], entity_mentions jsonb, published_at, source_name, source_platform, score, comment_count), reports (report_data jsonb, generated_at), graph_snapshots (computed_at, topic_clusters jsonb, entity_importance jsonb, metadata jsonb). Use SELECT only.",
          "max_attempts": 3
        },
        "parameters": {}
      },
      "ui": {
