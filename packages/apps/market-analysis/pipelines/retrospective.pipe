          "database": "neo4j",
          "db_description": "Pulsar knowledge graph. Nodes: Article (id, publishedAt), Topic (name, trendScore), Entity (name, type), Author, Source. Relationships: Article-[:TAGGED_WITH]->Topic, Article-[:MENTIONS]->Entity, Topic-[:RELATED_TO {weight}]-Topic. Use MATCH queries only, no writes. Note: graph snapshots themselves live in Postgres (graph_snapshots table), not in Neo4j.",
          "max_attempts": 3
        },
        "parameters": {}
      },
